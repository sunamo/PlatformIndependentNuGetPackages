<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>SunamoExceptions</AssemblyName>
    <RootNamespace>SunamoExceptions</RootNamespace>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <IsPackable>false</IsPackable>
    <DefineConstants>$(DefineConstants);ASYNC</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\SunamoExceptions\SunamoExceptions\**\*.cs"
             Exclude="..\SunamoExceptions\SunamoExceptions\obj\**\*;..\SunamoExceptions\SunamoExceptions\bin\**\*;..\SunamoExceptions\SunamoExceptions\ExceptionsIsNullOrWhitespace.cs;..\SunamoExceptions\SunamoExceptions\ExceptionsOnlyReturnString.cs;..\SunamoExceptions\SunamoExceptions\ExceptionsOther.cs;..\SunamoExceptions\SunamoExceptions\ThrowExOther.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="8.0.0" />
  </ItemGroup>
</Project>
