<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>annotations</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>SunamoDevCodeCore</AssemblyName>
    <RootNamespace>SunamoDevCode</RootNamespace>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <IsPackable>false</IsPackable>
    <DefineConstants>$(DefineConstants);ASYNC</DefineConstants>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="..\SunamoDevCodeCore\SunamoDevCodeCore\**\*.cs"
             Exclude="..\SunamoDevCodeCore\SunamoDevCodeCore\obj\**\*;..\SunamoDevCodeCore\SunamoDevCodeCore\bin\**\*" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="SunamoDevCodeBase.Net48.csproj" />
    <ProjectReference Include="SunamoCSharp.Net48.csproj" />
    <ProjectReference Include="SunamoSolutionsIndexer.Net48.csproj" />
  </ItemGroup>
</Project>