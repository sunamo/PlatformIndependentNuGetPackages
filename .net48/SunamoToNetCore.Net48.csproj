<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>annotations</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>SunamoToNetCore</AssemblyName>
    <RootNamespace>SunamoDevCode</RootNamespace>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <IsPackable>false</IsPackable>
    <DefineConstants>$(DefineConstants);ASYNC</DefineConstants>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="..\SunamoToNetCore\SunamoToNetCore\**\*.cs"
             Exclude="..\SunamoToNetCore\SunamoToNetCore\obj\**\*;..\SunamoToNetCore\SunamoToNetCore\bin\**\*" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="SunamoDevCodeBase.Net48.csproj" />
    <ProjectReference Include="SunamoSolutionsIndexer.Net48.csproj" />
    <ProjectReference Include="SunamoAps.Net48.csproj" />
  </ItemGroup>
</Project>